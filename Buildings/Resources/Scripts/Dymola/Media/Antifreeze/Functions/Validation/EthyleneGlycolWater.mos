createPlot(id=2, position={644, 58, 624, 646}, x="X_a", y={"eta"}, range={0.0, 0.6, 0.0, 0.006}, grid=true, subPlot=102, colors={{28,108,200}}, timeUnit="1", displayUnits={"Pa.s"});
createPlot(id=2, position={644, 58, 624, 646}, x="X_a", y={"Tf"}, range={0.0, 0.6, -60.0, 20.0}, grid=true, subPlot=103, colors={{28,108,200}}, timeUnit="1", displayUnits={"degC"});
