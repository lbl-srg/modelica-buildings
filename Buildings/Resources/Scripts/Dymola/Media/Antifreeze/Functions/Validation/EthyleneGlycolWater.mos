createPlot(id=3, position={1293, 65, 592, 635}, x="X_a", y={"lambda"}, range={0.0, 0.6, 0.30000000000000004, 0.7000000000000001}, grid=true, subPlot=102, colors={{28,108,200}}, timeUnit="1", displayUnits={"W/(m.K)"});
