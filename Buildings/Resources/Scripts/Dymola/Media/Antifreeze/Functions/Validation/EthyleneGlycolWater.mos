simulateModel("Buildings.Media.Antifreeze.Functions.Validation.EthyleneGlycolWater", method="Cvode", tolerance=1e-06, resultFile="EthyleneGlycolWater");
createPlot(id=1, position={55, 55, 569, 439}, x="phi", y={"phi", "X_a_phi"}, range={0.0, 1.0, -0.2, 1.2}, grid=true, colors={{238,46,47}, {0,140,72}}, timeUnit="1", displayUnits={"1", "1"});
