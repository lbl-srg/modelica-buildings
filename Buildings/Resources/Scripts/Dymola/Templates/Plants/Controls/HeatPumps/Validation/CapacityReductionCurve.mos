simulateModel("Buildings.Templates.Plants.Controls.HeatPumps.Validation.CapacityReductionCurve",
    method="cvode",
    tolerance=1e-6,
    stopTime=3600.0,
    resultFile="CapacityReductionCurve");
createPlot(id=1, position={0, 0, 1033, 840}, y={"curCapRed.TOut"}, range={0.0, 3600.0, -30.0, 40.0}, grid=true, subPlot=101, colors={{28,108,200}}, timeUnit="s", displayUnits={"degC"});
createPlot(id=1, position={0, 0, 1033, 840}, y={"curCapRed.THeaWatSup"}, range={0.0, 3600.0, 40.0, 160.0}, grid=true, subPlot=102, colors={{28,108,200}}, timeUnit="s", displayUnits={"degC"});
createPlot(id=1, position={0, 0, 1033, 840}, y={"curCapRed.y"}, range={0.0, 3600.0, -0.2, 1.4}, grid=true, subPlot=103, colors={{28,108,200}}, timeUnit="s");
