simulateModel("Buildings.Templates.Plants.Controls.StagingRotation.BaseClasses.Validation.RemoveFromStagingOrder",
    method="cvode",
    tolerance=1e-6,
    stopTime=6.0,
    resultFile="RemoveFromStagingOrder");
createPlot(
