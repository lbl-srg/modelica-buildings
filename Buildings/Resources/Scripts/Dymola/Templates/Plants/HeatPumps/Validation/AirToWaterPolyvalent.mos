simulateModel("Buildings.Templates.Plants.HeatPumps.Validation.AirToWaterPolyvalent",
    method="cvode",
    tolerance=1e-6,
    startTime=0.0,
    stopTime=86400.0,
    resultFile="AirToWaterPolyvalentPlant");
