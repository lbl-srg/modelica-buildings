within Buildings.Fluid.Humidifiers.EvaporativePads.Data;
package EvapcoTest
  annotation (Documentation(info="<html>
<p>
This package contains performance data for evaporative pads from several manufacturers 
that are tested by Evapco.
</p>
<p>
Details of the test and the resulting data points for each evaporative pad can be found in
<a href=\"https://www.evapco.com/sites/evapco.com/files/2019-02/Adiabatic-Pad-Saturation-White-Paper-11.2018.pdf\">
Adiabatic-Pad-Saturation-White-Paper-11.2018.pdf</a>.
</p>
</html>"));
end EvapcoTest;
